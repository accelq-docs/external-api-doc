---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import { parseSwaggerJson, getSwaggerFilePath, loadSwaggerFile, loadRequestConfig, loadTemplateFile } from '../../utils/swagger-parser';

export async function getStaticPaths() {
  const apiDocDataPath = path.join(process.cwd(), 'api_doc_data');

  // Get all group directories
  const groupDirs = fs.readdirSync(apiDocDataPath, { withFileTypes: true })
    .filter(dirent => dirent.isDirectory())
    .map(dirent => dirent.name);

  const paths = [];

  for (const groupName of groupDirs) {
    const groupPath = path.join(apiDocDataPath, groupName);

    // Get Swagger/OpenAPI file
    const swaggerFilePath = getSwaggerFilePath(groupPath, fs);

    if (!swaggerFilePath) {
      console.warn(`No swagger.json or openapi.json found in ${groupName}, skipping...`);
      continue;
    }

    // Parse Swagger file and generate endpoints
    const swaggerDoc = loadSwaggerFile(swaggerFilePath, fs);
    const requestConfig = loadRequestConfig(groupPath, fs);
    const customTemplate = loadTemplateFile(groupPath, fs);
    if (swaggerDoc) {
      const endpoints = parseSwaggerJson(swaggerDoc, groupName, requestConfig || undefined, customTemplate);

      for (const endpoint of endpoints) {
        paths.push({
          params: { slug: endpoint.slug },
          props: {
            requestInfo: endpoint.requestInfo,
            curlContent: endpoint.curlContent,
            templateContent: endpoint.templateContent,
            responses: endpoint.responses,
            statusReasons: endpoint.statusReasons,
            requestPayload: endpoint.requestPayload,
            payloadExamples: endpoint.payloadExamples,
            groupName
          }
        });
      }
    }
  }

  return paths;
}

interface ParamInfo {
  type: string;
  description: string;
  required?: boolean;
  default?: string;
  in?: string; // path, query, header, body
  enum?: string[];
}

interface PayloadExample {
  name: string;
  payload: string;
}

interface Props {
  requestInfo: {
    name: string;
    description: string;
    request_url: string;
    method: string;
    headers: Record<string, string>;
    parameters?: Record<string, ParamInfo>;
    response_status_codes?: string[];
  };
  curlContent: string;
  templateContent: string;
  responses: Record<string, string>;
  statusReasons: Record<string, string>;
  requestPayload: string;
  payloadExamples?: PayloadExample[];
  groupName: string;
}

const { requestInfo, curlContent, templateContent, responses, statusReasons, requestPayload, payloadExamples } = Astro.props;
const parameters = requestInfo.parameters || {};

// Helper function to clean description for placeholder (remove markdown formatting)
function cleanDescriptionForPlaceholder(desc: string): string {
  return desc
    .replace(/\*\*([^*]+)\*\*/g, '$1') // Remove bold **text**
    .replace(/\n/g, ' ') // Replace newlines with spaces
    .replace(/\s+/g, ' ') // Collapse multiple spaces
    .replace(/^-\s+/gm, '') // Remove list markers
    .trim()
    .split('.')[0] + '.'; // Take only first sentence
}

// Helper functions for formatting
function formatHeaders(headers: Record<string, string>): string {
  if (!headers || Object.keys(headers).length === 0) return '';
  let table = '| Header | Value |\n|--------|-------|\n';
  for (const [key, value] of Object.entries(headers)) {
    table += `| \`${key}\` | ${value} |\n`;
  }
  return table;
}

function formatAllParameters(params: Record<string, ParamInfo> | undefined): string {
  if (!params || Object.keys(params).length === 0) return '';
  let result = '| Parameter | Type | Required | Description |\n|-----------|------|----------|-------------|\n';
  for (const [key, info] of Object.entries(params)) {
    const required = info.required ? 'Yes' : 'No';
    // Replace newlines with <br> and escape pipe characters in description
    const sanitizedDesc = info.description
      .replace(/\n/g, '<br>')
      .replace(/\|/g, '\\|');
    result += `| \`${key}\` | ${info.type} | ${required} | ${sanitizedDesc} |\n`;
  }
  return result;
}

// Format parameters section with example selector if multiple examples exist
function formatParametersWithExamples(params: Record<string, ParamInfo> | undefined): string {
  if (!params || Object.keys(params).length === 0) return '';
  let result = '';

  // Add the parameters table in a container that can be replaced
  result += '<div id="parameters-container">\n';
  result += formatAllParameters(params);
  result += '</div>\n\n';

  // Add example selector dropdown AFTER parameters if multiple examples exist
  if (payloadExamples && payloadExamples.length > 1) {
    result += '<div class="example-selector-section">\n';
    result += '<label for="doc-example-selector"><strong>Select Examples:</strong></label>\n';
    result += '<select id="doc-example-selector" class="example-dropdown">\n';
    payloadExamples.forEach((example, index) => {
      result += `<option value="${index}"${index === 0 ? ' selected' : ''}>${example.name}</option>\n`;
    });
    result += '</select>\n';
    result += '</div>\n';
  }

  return result;
}

function formatResponses(responses: Record<string, string>, statusCodes: string[], statusReasons: Record<string, string>): string {
  if (!statusCodes || statusCodes.length === 0) return '';

  // Fallback labels if no status.reason file exists
  const defaultLabels: Record<string, string> = {
    '200': 'Success',
    '201': 'Created',
    '204': 'No Content',
    '400': 'Bad Request',
    '401': 'Unauthorized',
    '403': 'Forbidden',
    '404': 'Not Found',
    '500': 'Internal Server Error'
  };

  let result = '';
  for (const code of statusCodes) {
    // Use custom status.reason if available, otherwise fall back to default
    const label = statusReasons[code] || defaultLabels[code] || 'Response';
    result += `### ${code} - ${label}\n\n`;
    if (responses[code]) {
      // Try to parse and re-format JSON for proper display
      let formattedJson = responses[code].trim();
      try {
        const parsed = JSON.parse(formattedJson);
        formattedJson = JSON.stringify(parsed, null, 2);
      } catch {
        // If not valid JSON, use as-is
      }
      // Use special marker for response blocks (no copy button)
      result += '```json-response\n' + formattedJson + '\n```\n\n';
    } else {
      result += '*No response sample available*\n\n';
    }
  }
  return result;
}

// Generate curl command dynamically
function generateCurlPreview(): string {
  const method = requestInfo.method;
  let url = requestInfo.request_url;

  // Build headers string
  let headersStr = '';
  for (const [key, value] of Object.entries(requestInfo.headers)) {
    headersStr += `\n  -H "${key}: ${value}" \\`;
  }

  // Build body for POST/PUT/PATCH
  let bodyStr = '';
  if (['POST', 'PUT', 'PATCH'].includes(method) && parameters.body) {
    const bodyObj: Record<string, string> = {};
    for (const [key, _info] of Object.entries(parameters.body)) {
      bodyObj[key] = `<${key}>`;
    }
    bodyStr = `\n  -d '${JSON.stringify(bodyObj, null, 2)}'`;
  }

  return `curl -X ${method} "${url}" \\${headersStr}${bodyStr}`;
}

// Format endpoint bar with styled method badge
function formatEndpointBar(method: string, url: string): string {
  const methodLower = method.toLowerCase();
  return `<div class="endpoint-bar"><span class="method method-${methodLower}">${method}</span><code class="endpoint-url">${url}</code></div>`;
}

// Replace placeholders in template
let renderedContent = templateContent;

renderedContent = renderedContent.replace(/\{\{API_NAME\}\}/g, requestInfo.name);
renderedContent = renderedContent.replace(/\{\{API_DESCRIPTION\}\}/g, requestInfo.description);
renderedContent = renderedContent.replace(/\{\{METHOD\}\}/g, requestInfo.method);
renderedContent = renderedContent.replace(/\{\{REQUEST_URL\}\}/g, requestInfo.request_url);
renderedContent = renderedContent.replace(/\{\{ENDPOINT_BAR\}\}/g, formatEndpointBar(requestInfo.method, requestInfo.request_url));
renderedContent = renderedContent.replace(/\{\{HEADERS\}\}/g, formatHeaders(requestInfo.headers));
renderedContent = renderedContent.replace(/\{\{PARAMETERS\}\}/g, formatParametersWithExamples(parameters));

// Format request payload section
function formatRequestPayload(payload: string): string {
  if (!payload || payload.trim() === '' || payload.trim() === '{}') return '';
  let result = '';

  result += '## Request Body\n\n';
  result += '<div id="payload-container">';
  result += '```json-payload\n' + payload + '\n```\n';
  result += '</div>';
  return result;
}
renderedContent = renderedContent.replace(/\{\{REQUEST_PAYLOAD\}\}/g, formatRequestPayload(requestPayload));
renderedContent = renderedContent.replace(/\{\{RESPONSES\}\}/g, formatResponses(responses, requestInfo.response_status_codes || [], statusReasons));

// Remove INTERACTIVE_SECTION placeholder - we'll render it separately
renderedContent = renderedContent.replace(/\{\{INTERACTIVE_SECTION\}\}/g, '');

// Also handle old format for backward compatibility
renderedContent = renderedContent.replace(/\{\{ENDPOINT\}\}/g, requestInfo.request_url);
renderedContent = renderedContent.replace(/\{\{CURL\}\}/g, '');

// Markdown to HTML conversion
function markdownToHtml(md: string): string {
  let html = md;

  // Store code blocks temporarily to prevent them from being processed by paragraph regex
  const codeBlocks: string[] = [];
  html = html.replace(/```([\w-]+)?\n([\s\S]*?)```/g, (_match, lang, code) => {
    const language = lang || 'text';
    const escapedCode = code
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');

    let block: string;
    // Response blocks don't get a copy button, payload blocks do get copy button
    if (language === 'json-response') {
      block = `<div class="code-block response-block"><div class="code-header"><span class="lang">json</span></div><pre><code>${escapedCode}</code></pre></div>`;
    } else if (language === 'json-payload') {
      block = `<div class="code-block payload-block"><div class="code-header"><span class="lang">json</span><button class="copy-btn code-copy-btn">Copy</button></div><pre><code>${escapedCode}</code></pre></div>`;
    } else {
      // Regular code blocks get copy button
      block = `<div class="code-block"><div class="code-header"><span class="lang">${language}</span><button class="copy-btn code-copy-btn">Copy</button></div><pre><code>${escapedCode}</code></pre></div>`;
    }

    const placeholder = `__CODE_BLOCK_${codeBlocks.length}__`;
    codeBlocks.push(block);
    return placeholder;
  });

  // Tables
  html = html.replace(/\|(.+)\|\n\|[-|\s]+\|\n((?:\|.+\|\n?)+)/g, (_match, header, rows) => {
    const headers = header.split('|').map((h: string) => h.trim()).filter(Boolean);
    const headerHtml = headers.map((h: string) => `<th>${h}</th>`).join('');

    const rowLines = rows.trim().split('\n');
    const rowsHtml = rowLines.map((row: string) => {
      const cells = row.split('|').map((c: string) => c.trim()).filter(Boolean);
      return `<tr>${cells.map((c: string) => `<td>${c}</td>`).join('')}</tr>`;
    }).join('');

    return `<table><thead><tr>${headerHtml}</tr></thead><tbody>${rowsHtml}</tbody></table>`;
  });

  // Horizontal rule
  html = html.replace(/^---$/gm, '<hr />');

  // Headers
  html = html.replace(/^#### (.+)$/gm, '<h4>$1</h4>');
  html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
  html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
  html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');

  // Bold and inline code
  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

  // Lists
  html = html.replace(/^- (.+)$/gm, '<li>$1</li>');
  html = html.replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>');

  // Paragraphs - exclude lines starting with HTML tags or placeholders
  html = html.replace(/^(?!<[a-z]|__|$)(.+)$/gm, '<p>$1</p>');
  html = html.replace(/<p>\s*<\/p>/g, '');

  // Italics
  html = html.replace(/\*([^*]+)\*/g, '<em>$1</em>');

  // Restore code blocks
  codeBlocks.forEach((block, index) => {
    html = html.replace(`__CODE_BLOCK_${index}__`, block);
  });

  return html;
}

const htmlContent = markdownToHtml(renderedContent);

// Prepare data for interactive section
const interactiveData = {
  method: requestInfo.method,
  request_url: requestInfo.request_url,
  headers: requestInfo.headers,
  parameters: parameters,
  curlContent: curlContent,
  payloadExamples: payloadExamples || [],
  defaultParameters: parameters // Store default parameters (from first example or API spec)
};
---

<Layout title={requestInfo.name}>
  <article class="api-doc">
    <div class="rendered-content" set:html={htmlContent} />

    <!-- Interactive Section -->
    <section class="interactive-section">
      <h2>
        <!-- <svg class="gear-svg" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M15 12C15 13.6569 13.6569 15 12 15C10.3431 15 9 13.6569 9 12C9 10.3431 10.3431 9 12 9C13.6569 9 15 10.3431 15 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M12.9046 3.06005C12.6988 3 12.4659 3 12 3C11.5341 3 11.3012 3 11.0954 3.06005C10.7942 3.14794 10.5281 3.32808 10.3346 3.57511C10.2024 3.74388 10.1159 3.96016 9.94291 4.39272C9.69419 5.01452 9.00393 5.33471 8.36857 5.123L7.79779 4.93281C7.3929 4.79785 7.19045 4.73036 6.99196 4.7188C6.70039 4.70181 6.4102 4.77032 6.15701 4.9159C5.98465 5.01501 5.83376 5.16591 5.53197 5.4677C5.21122 5.78845 5.05084 5.94882 4.94896 6.13189C4.79927 6.40084 4.73595 6.70934 4.76759 7.01551C4.78912 7.2239 4.87335 7.43449 5.04182 7.85566C5.30565 8.51523 5.05184 9.26878 4.44272 9.63433L4.16521 9.80087C3.74031 10.0558 3.52786 10.1833 3.37354 10.3588C3.23698 10.5141 3.13401 10.696 3.07109 10.893C3 11.1156 3 11.3658 3 11.8663C3 12.4589 3 12.7551 3.09462 13.0088C3.17823 13.2329 3.31422 13.4337 3.49124 13.5946C3.69158 13.7766 3.96395 13.8856 4.50866 14.1035C5.06534 14.3261 5.35196 14.9441 5.16236 15.5129L4.94721 16.1584C4.79819 16.6054 4.72367 16.829 4.7169 17.0486C4.70875 17.3127 4.77049 17.5742 4.89587 17.8067C5.00015 18.0002 5.16678 18.1668 5.5 18.5C5.83323 18.8332 5.99985 18.9998 6.19325 19.1041C6.4258 19.2295 6.68733 19.2913 6.9514 19.2831C7.17102 19.2763 7.39456 19.2018 7.84164 19.0528L8.36862 18.8771C9.00393 18.6654 9.6942 18.9855 9.94291 19.6073C10.1159 20.0398 10.2024 20.2561 10.3346 20.4249C10.5281 20.6719 10.7942 20.8521 11.0954 20.94C11.3012 21 11.5341 21 12 21C12.4659 21 12.6988 21 12.9046 20.94C13.2058 20.8521 13.4719 20.6719 13.6654 20.4249C13.7976 20.2561 13.8841 20.0398 14.0571 19.6073C14.3058 18.9855 14.9961 18.6654 15.6313 18.8773L16.1579 19.0529C16.605 19.2019 16.8286 19.2764 17.0482 19.2832C17.3123 19.2913 17.5738 19.2296 17.8063 19.1042C17.9997 18.9999 18.1664 18.8333 18.4996 18.5001C18.8328 18.1669 18.9994 18.0002 19.1037 17.8068C19.2291 17.5743 19.2908 17.3127 19.2827 17.0487C19.2759 16.8291 19.2014 16.6055 19.0524 16.1584L18.8374 15.5134C18.6477 14.9444 18.9344 14.3262 19.4913 14.1035C20.036 13.8856 20.3084 13.7766 20.5088 13.5946C20.6858 13.4337 20.8218 13.2329 20.9054 13.0088C21 12.7551 21 12.4589 21 11.8663C21 11.3658 21 11.1156 20.9289 10.893C20.866 10.696 20.763 10.5141 20.6265 10.3588C20.4721 10.1833 20.2597 10.0558 19.8348 9.80087L19.5569 9.63416C18.9478 9.26867 18.6939 8.51514 18.9578 7.85558C19.1262 7.43443 19.2105 7.22383 19.232 7.01543C19.2636 6.70926 19.2003 6.40077 19.0506 6.13181C18.9487 5.94875 18.7884 5.78837 18.4676 5.46762C18.1658 5.16584 18.0149 5.01494 17.8426 4.91583C17.5894 4.77024 17.2992 4.70174 17.0076 4.71872C16.8091 4.73029 16.6067 4.79777 16.2018 4.93273L15.6314 5.12287C14.9961 5.33464 14.3058 5.0145 14.0571 4.39272C13.8841 3.96016 13.7976 3.74388 13.6654 3.57511C13.4719 3.32808 13.2058 3.14794 12.9046 3.06005Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg> -->
        cURL Command Builder
      </h2>

      {Object.keys(parameters).length > 0 && (
        <>
          {/* URL/Path Parameters */}
          {Object.entries(parameters).filter(([_, info]) => info.in === 'path' || info.in === 'query').length > 0 && (
            <div class="editable-group">
              <h4>URL Parameters</h4>
              {Object.entries(parameters).filter(([_, info]) => info.in === 'path' || info.in === 'query').map(([key, info]: [string, ParamInfo]) => (
                <div class="editable-field">
                  <label>
                    {key} <span class="field-type">({info.type})</span>
                    {info.required && <span class="required">*</span>}
                  </label>
                  {info.enum && info.enum.length > 0 ? (
                    <select data-param-name={key} data-default={info.default || info.enum[0]}>
                      {info.enum.map((enumValue: string) => (
                        <option value={enumValue} selected={enumValue === (info.default || info.enum[0])}>
                          {enumValue}
                        </option>
                      ))}
                    </select>
                  ) : info.type === 'boolean' ? (
                    <select data-param-name={key} data-default={info.default || 'false'}>
                      <option value="true" selected={(info.default || 'false') === 'true'}>true</option>
                      <option value="false" selected={(info.default || 'false') === 'false'}>false</option>
                    </select>
                  ) : (
                    <input type="text" data-param-name={key} data-default={info.default || ''} value={info.default || ''} placeholder={cleanDescriptionForPlaceholder(info.description)} />
                  )}
                </div>
              ))}
            </div>
          )}

          {/* Header Parameters */}
          {Object.entries(parameters).filter(([_, info]) => info.in === 'header').length > 0 && (
            <div class="editable-group">
              <h4>Headers</h4>
              {Object.entries(parameters).filter(([_, info]) => info.in === 'header').map(([key, info]: [string, ParamInfo]) => (
                <div class="editable-field">
                  <label>
                    {key} <span class="field-type">({info.type})</span>
                    {info.required && <span class="required">*</span>}
                  </label>
                  <input type="text" data-param-name={key} data-default={info.default || ''} value={info.default || ''} placeholder={cleanDescriptionForPlaceholder(info.description)} />
                </div>
              ))}
            </div>
          )}
        </>
      )}

      <div class="curl-block">
        <div class="curl-header">
          <h4>Request Sample (cURL)</h4>
          <button class="copy-btn" id="copy-curl-btn">Copy</button>
        </div>
        <pre id="curl-output">{curlContent || generateCurlPreview()}</pre>
      </div>
    </section>
  </article>
</Layout>

<script is:inline define:vars={{ interactiveData }}>
  // Check for embed mode via query parameter
  (function() {
    const urlParams = new URLSearchParams(window.location.search);
    const isEmbed = urlParams.get('embed') === 'true';

    if (isEmbed) {
      document.body.classList.add('embed-mode');
      // Apply overflow hidden to html only in embed mode
      document.documentElement.style.overflow = 'hidden';
      // Hide the h1 (API name) and first paragraph (description)
      const renderedContent = document.querySelector('.rendered-content');
      if (renderedContent) {
        const h1 = renderedContent.querySelector('h1');
        if (h1) h1.style.display = 'none';
        // Hide the first paragraph after h1 (description)
        const firstP = renderedContent.querySelector('p');
        if (firstP) firstP.style.display = 'none';
      }
    }
  })();

  // Get the curl template
  const curlTemplate = interactiveData.curlContent;
  let currentPayload = null; // Track current payload from example selector

  // Update cURL by replacing ${{paramName}} placeholders with input/select values
  function updateCurl() {
    let curl = curlTemplate;

    // Replace all parameters from inputs and selects
    document.querySelectorAll('.editable-field input, .editable-field select').forEach(element => {
      // Skip the example selector
      if (element.id === 'example-selector') return;

      const name = element.getAttribute('data-param-name');
      const defaultValue = element.getAttribute('data-default') || `<${name}>`;
      const value = element.value || defaultValue;
      // Replace ${{paramName}} pattern
      const pattern = new RegExp('\\$\\{\\{' + name + '\\}\\}', 'g');
      curl = curl.replace(pattern, value);
    });

    // If a different payload is selected, replace the -d '...' section
    if (currentPayload) {
      // Find and replace the -d '...' part
      curl = curl.replace(/-d\s+'[^']*'/g, `-d '${currentPayload.replace(/'/g, "\\'")}'`);
    }

    document.getElementById('curl-output').textContent = curl;
  }

  // Initialize curl with default values on page load
  updateCurl();

  // Add event listeners for live updates
  document.querySelectorAll('.editable-field input, .editable-field select').forEach(element => {
    element.addEventListener('input', updateCurl);
    element.addEventListener('change', updateCurl);
  });

  // Handle example selector in documentation if payload examples exist
  const docExampleSelector = document.getElementById('doc-example-selector');
  if (docExampleSelector && interactiveData.payloadExamples && interactiveData.payloadExamples.length > 0) {
    docExampleSelector.addEventListener('change', function() {
      const selectedIndex = parseInt(this.value);
      const selectedExample = interactiveData.payloadExamples[selectedIndex];

      if (selectedExample) {
        // Update the current payload for cURL
        currentPayload = selectedExample.payload;

        // Update the payload code block in the rendered content
        const payloadBlock = document.querySelector('.rendered-content .payload-block code');
        if (payloadBlock) {
          // Format the JSON nicely
          const formattedPayload = selectedExample.payload
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');
          payloadBlock.innerHTML = formattedPayload;
        }

        // Update the cURL command with the new payload
        updateCurl();
      }
    });
  }

  // Copy button for cURL
  document.getElementById('copy-curl-btn').addEventListener('click', () => {
    const curlText = document.getElementById('curl-output').textContent;
    navigator.clipboard.writeText(curlText);
    const btn = document.getElementById('copy-curl-btn');
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 2000);
  });

  // Copy buttons for code blocks (payload and regular code blocks)
  document.querySelectorAll('.code-copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const codeBlock = btn.closest('.code-block');
      const codeText = codeBlock.querySelector('code').textContent;
      navigator.clipboard.writeText(codeText);
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 2000);
    });
  });
</script>

<style>
  html body{
    padding: 0;
    margin: 0;
  }
  .api-doc {
    max-width: 100%;
  }

  .api-header {
    margin-bottom: 1rem;
  }

  .api-description {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .api-description :global(p) {
    margin: 0.5rem 0;
  }

  .api-description :global(p:first-child) {
    margin-top: 0;
  }

  .api-description :global(p:last-child) {
    margin-bottom: 0;
  }

  .api-description :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .api-description :global(ul) {
    margin: 0.5rem 0;
    padding-left: 1.5rem;
  }

  .api-description :global(li) {
    margin: 0.25rem 0;
  }


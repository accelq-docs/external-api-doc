---
import CodeBlock from './CodeBlock.astro';

interface Props {
  statusCode: string;
  content: string;
}

const { statusCode, content } = Astro.props;

const statusInfo: Record<string, { label: string; class: string }> = {
  '200': { label: 'OK', class: 'status-success' },
  '201': { label: 'Created', class: 'status-success' },
  '204': { label: 'No Content', class: 'status-success' },
  '400': { label: 'Bad Request', class: 'status-error' },
  '401': { label: 'Unauthorized', class: 'status-error' },
  '403': { label: 'Forbidden', class: 'status-error' },
  '404': { label: 'Not Found', class: 'status-error' },
  '500': { label: 'Internal Server Error', class: 'status-error' },
  '502': { label: 'Bad Gateway', class: 'status-error' },
  '503': { label: 'Service Unavailable', class: 'status-error' },
};

const info = statusInfo[statusCode] || { label: 'Response', class: 'status-default' };
---

<div class="response-section">
  <div class="response-header">
    <span class={`status-badge ${info.class}`}>
      {statusCode}
    </span>
    <span class="status-label">{info.label}</span>
  </div>
  <CodeBlock code={content} language="json" />
</div>

<style>
  .response-section {
    border: 1px solid #334155;
    border-radius: 8px;
    overflow: hidden;
  }

  .response-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background-color: #1e293b;
    border-bottom: 1px solid #334155;
  }

  .status-badge {
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.875rem;
    font-family: monospace;
  }

  .status-success {
    background-color: #059669;
    color: #ecfdf5;
  }

  .status-error {
    background-color: #dc2626;
    color: #fef2f2;
  }

  .status-default {
    background-color: #64748b;
    color: #f1f5f9;
  }

  .status-label {
    color: #94a3b8;
    font-size: 0.875rem;
  }

  .response-section :global(.code-block) {
    border: none;
    border-radius: 0;
  }

  .response-section :global(.code-header) {
    display: none;
  }
</style>
